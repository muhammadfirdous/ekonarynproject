<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/successPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅" android:textSize="48sp" android:layout_marginBottom="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/collect_success_title" android:textColor="@color/text_primary"
                android:textSize="20sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/collect_success_sub" android:textColor="@color/text_gray"
                android:textSize="14sp" android:gravity="center" android:layout_marginTop="8dp" />
            <Button android:id="@+id/btnAnother" style="@style/PrimaryButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="24dp" android:text="@string/collect_success_another" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/formPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/collect_choose_request" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/requestChips"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <TextView
                android:id="@+id/noAssignedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:gravity="center"
                android:text="@string/collect_no_assigned"
                android:textColor="@color/text_gray"
                android:background="@drawable/bg_card"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/collect_material" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/materialChips"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/collect_actual_weight" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/inputWeight" style="@style/InputField"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="0.0" android:inputType="numberDecimal"
                android:layout_marginBottom="16dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/collect_notes" android:textSize="14sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp" />
            <EditText android:id="@+id/inputNotes" style="@style/InputField"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/collect_notes_placeholder"
                android:inputType="textMultiLine" android:minLines="3"
                android:gravity="top|start" android:layout_marginBottom="24dp" />

            <Button android:id="@+id/btnSubmit" style="@style/PrimaryButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="@string/collect_submit"
                android:layout_marginBottom="32dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
