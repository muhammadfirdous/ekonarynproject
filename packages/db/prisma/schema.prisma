generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(uuid())
  name        String
  phone       String          @unique
  email       String?         @unique
  password    String
  role        String          @default("RESIDENT")
  address     String?
  points      Int             @default(0)
  createdAt   DateTime        @default(now())

  // Account lifecycle
  accountStatus            String   @default("ACTIVE")
  statusReason             String?
  statusChangedAt          DateTime?
  statusChangedById        String?

  // Verification
  emailVerifiedAt          DateTime?
  phoneVerifiedAt          DateTime?
  verificationCode         String?
  verificationCodeExpiresAt DateTime?

  // Worker-specific
  idNumber                 String?
  idDocumentUrl            String?
  serviceAreas             String?   // JSON array
  vehicleType              String?
  vehiclePlate             String?
  vehicleCapacityKg        Float?
  maxConcurrentOrders      Int?      @default(5)
  onShift                  Boolean   @default(false)

  // Soft delete
  deletedAt   DateTime?

  collections      Collection[]
  requests         PickupRequest[]      @relation("ResidentRequests")
  assignedRequests PickupRequest[]      @relation("AssignedWorkerRequests")
  routes           Route[]
  trips            Trip[]

  @@index([accountStatus])
  @@index([role])
}

model Material {
  id           String          @id @default(uuid())
  name         String
  nameKy       String
  nameRu       String
  buyingPrice  Float
  sellingPrice Float
  unit         String          @default("kg")
  description  String?
  imageUrl     String?
  requests     PickupRequest[]
  collections  Collection[]
}

model PickupRequest {
  id                 String      @id @default(uuid())
  resident           User        @relation("ResidentRequests", fields: [residentId], references: [id])
  residentId         String
  material           Material    @relation(fields: [materialId], references: [id])
  materialId         String
  address            String
  estimatedQty       Float
  status             String      @default("pending")
  notes              String?
  createdAt          DateTime    @default(now())
  assignedWorker     User?       @relation("AssignedWorkerRequests", fields: [assignedWorkerId], references: [id])
  assignedWorkerId   String?
  assignedAt         DateTime?
  cancellationReason String?
  deletedAt          DateTime?
  collection         Collection?

  @@index([status])
  @@index([assignedWorkerId])
  @@index([createdAt])
}

model Collection {
  id             String        @id @default(uuid())
  worker         User          @relation(fields: [workerId], references: [id])
  workerId       String
  request        PickupRequest @relation(fields: [requestId], references: [id])
  requestId      String        @unique
  material       Material      @relation(fields: [materialId], references: [id])
  materialId     String
  actualWeightKg Float
  photoUrl       String?
  notes          String?
  collectedAt    DateTime      @default(now())
  trip           Trip?         @relation(fields: [tripId], references: [id])
  tripId         String?
}

model Trip {
  id            String       @id @default(uuid())
  worker        User         @relation(fields: [workerId], references: [id])
  workerId      String
  date          DateTime
  destination   String       @default("Bishkek")
  totalWeightKg Float        @default(0)
  transportCost Float        @default(0)
  revenue       Float        @default(0)
  collections   Collection[]
  createdAt     DateTime     @default(now())
}

model Route {
  id        String   @id @default(uuid())
  worker    User     @relation(fields: [workerId], references: [id])
  workerId  String
  date      DateTime
  stops     String
  status    String   @default("active")
  createdAt DateTime @default(now())
}

model FinancialRecord {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  description String
  category    String?
  date        DateTime
  createdAt   DateTime @default(now())
}

model Schedule {
  id        String  @id @default(uuid())
  area      String
  dayOfWeek Int
  time      String
  active    Boolean @default(true)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String?
  metadata   String?  // JSON string
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
}
