# Database
DATABASE_URL=postgresql://ekonaryn:ekonaryn_pass@localhost:5432/ekonaryn

# JWT
# CHANGE BEFORE DEPLOY — generate via: openssl rand -base64 48
# In NODE_ENV=production the API refuses to start if these still match the
# defaults below (see packages/api/src/utils/startup.ts).
JWT_SECRET=dev-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=4000
API_URL=http://localhost:4000

# CORS — comma-separated list of allowed browser origins. Mobile/curl/S2S
# callers send no Origin and are always allowed through.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Phone verification gate. Until an SMS provider is integrated (DEPLOYMENT.md
# §0.8 / §7.1), set SKIP_PHONE_VERIFICATION=true so new registrations are
# auto-verified and /auth/verify/resend returns 400 VERIFICATION_DISABLED.
# Default is `false` so dev / test flows exercise the real verification path.
SKIP_PHONE_VERIFICATION=false

# Next.js (Website)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Next.js (Dashboard)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# PostgreSQL (Docker)
POSTGRES_USER=ekonaryn
POSTGRES_PASSWORD=ekonaryn_pass
POSTGRES_DB=ekonaryn

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@ekonaryn.kg
PGADMIN_DEFAULT_PASSWORD=admin123

# Production deploy (docker-compose.prod.yml). GHCR_OWNER is the GitHub
# organisation/user that owns the published images; IMAGE_TAG pins which
# tag to pull (default `latest`, override per-deploy via .env.deploy as
# documented in DEPLOYMENT.md §8.2).
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# Optional: rclone remote + bucket for off-VPS backups (deploy/scripts/backup.sh).
# Leave blank to keep backups on the VPS only — single-VPS deploys with no
# off-host backups are explicitly called out as the v1 minimum risk in
# DEPLOYMENT.md §5.2.
BACKUP_REMOTE=
BACKUP_BUCKET=
